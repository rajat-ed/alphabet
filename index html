<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AlphaBet: The Rapid Fire Challenge</title>
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --secondary: #06b6d4;
            --dark: #0f172a;
            --light: #f8fafc;
            --danger: #ef4444;
            --success: #22c55e;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--dark);
            color: var(--light);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .game-container {
            background-color: #1e293b;
            width: 100%;
            max-width: 600px;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            text-align: center;
            border: 1px solid #334155;
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 20px;
            color: #fff;
            letter-spacing: 1px;
        }

        h1 span {
            color: var(--secondary);
        }

        .screen {
            display: none;
        }

        .screen.active {
            display: block;
        }

        .btn {
            background-color: var(--primary);
            color: white;
            border: none;
            padding: 14px 28px;
            font-size: 1.1rem;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            margin: 10px;
            display: inline-block;
        }

        .btn:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
        }

        .btn-danger { background-color: var(--danger); }
        .btn-danger:hover { background-color: #dc2626; }
        .btn-success { background-color: var(--success); }
        .btn-success:hover { background-color: #16a34a; }

        .letter-display {
            font-size: 8rem;
            font-weight: 900;
            color: var(--secondary);
            margin: 20px 0;
            text-shadow: 0 0 20px rgba(6, 182, 212, 0.3);
            animation: popIn 0.3s ease;
        }

        @keyframes popIn {
            0% { transform: scale(0.8); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        .status-text {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #94a3b8;
        }

        .game-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 2px solid #334155;
        }

        .timer {
            font-size: 1.5rem;
            font-weight: 700;
            background-color: #334155;
            padding: 5px 15px;
            border-radius: 20px;
            color: #f59e0b;
        }

        .score {
            font-size: 1.2rem;
            font-weight: 600;
        }

        .question-box {
            font-size: 1.5rem;
            font-weight: 600;
            margin: 40px 0;
            min-height: 80px;
            display: flex;
            justify-content: center;
            align-items: center;
            line-height: 1.4;
        }

        .input-group {
            margin-bottom: 20px;
        }

        .answer-input {
            width: 100%;
            padding: 16px;
            font-size: 1.3rem;
            border-radius: 8px;
            border: 2px solid #334155;
            background-color: #0f172a;
            color: white;
            text-align: center;
            outline: none;
            transition: border-color 0.2s;
        }

        .answer-input:focus {
            border-color: var(--secondary);
        }

        .hint {
            font-size: 0.9rem;
            color: #64748b;
            margin-top: 8px;
        }

        .review-list {
            text-align: left;
            max-height: 300px;
            overflow-y: auto;
            margin: 20px 0;
            padding: 10px;
            background-color: #0f172a;
            border-radius: 8px;
        }

        .review-item {
            padding: 8px 12px;
            border-bottom: 1px solid #1e293b;
            display: flex;
            justify-content: space-between;
        }

        .review-item:last-child { border: none; }
        .txt-success { color: var(--success); }
        .txt-danger { color: var(--danger); }
    </style>
</head>
<body>

    <div class="game-container">
        <!-- SCREEN 1: START SCREEN -->
        <div id="start-screen" class="screen active">
            <h1>Alpha<span>Bet</span></h1>
            <p class="status-text">Test your vocabulary under extreme pressure. Get a letter, accept or gamble it, then answer as many rapid-fire questions as you can in 60 seconds.</p>
            <button class="btn" onclick="initiateLetterSelection()">Start Game</button>
        </div>

        <!-- SCREEN 2: LETTER DECISION SCREEN -->
        <div id="decision-screen" class="screen">
            <h2 id="decision-title">Your Letter Is...</h2>
            <div id="current-letter" class="letter-display">A</div>
            <p id="decision-status" class="status-text">Will you keep it or gamble for a new one?</p>
            <div id="decision-buttons">
                <button class="btn btn-success" onclick="acceptLetter()">Accept</button>
                <button class="btn btn-danger" id="reject-btn" onclick="rejectLetter()">Reject & Swap</button>
            </div>
        </div>

        <!-- SCREEN 3: GAMEPLAY SCREEN -->
        <div id="game-screen" class="screen">
            <div class="game-header">
                <div class="score">Score: <span id="live-score" class="txt-success">0</span></div>
                <div class="score">Letter: <span id="active-letter" style="color:var(--secondary)">A</span></div>
                <div class="timer" id="timer-display">60s</div>
            </div>
            <div class="question-box" id="question-display">Loading question...</div>
            <div class="input-group">
                <input type="text" id="answer-field" class="answer-input" placeholder="Type answer here..." autocomplete="off">
                <div class="hint">Press <strong>Enter</strong> to submit. Leave blank and press Enter to <strong>Skip</strong>.</div>
            </div>
        </div>

        <!-- SCREEN 4: GAME OVER SCREEN -->
        <div id="game-over-screen" class="screen">
            <h1>Game Over!</h1>
            <p class="status-text">You played with the letter <strong id="final-letter" style="color:var(--secondary)">-</strong></p>
            <div style="font-size: 2rem; font-weight: bold; margin: 20px 0;">
                Final Score: <span id="final-score" class="txt-success">0</span>
            </div>
            <h3>Your Answers:</h3>
            <div class="review-list" id="review-container"></div>
            <button class="btn" onclick="restartGame()">Play Again</button>
        </div>
    </div>

